{
	"eslint.format.enable": true,
	"editor.codeActionsOnSave": {
		"source.fixAll.eslint": "explicit",
		"source.organizeImports": "explicit"
	},
	"[javascript]": {
		"editor.codeActionsOnSave": {
			"source.fixAll.eslint": "explicit",
			"source.organizeImports": "explicit"
		},
		"editor.defaultFormatter": "dbaeumer.vscode-eslint"
	},
	"[typescript]": {
		"editor.codeActionsOnSave": {
			"source.fixAll.eslint": "explicit",
			"source.organizeImports": "explicit"
		},
		"editor.defaultFormatter": "dbaeumer.vscode-eslint"
	},
	"[typescriptreact]": {
		"editor.codeActionsOnSave": {
			"source.fixAll.eslint": "explicit",
			"source.organizeImports": "explicit"
		},
		"editor.defaultFormatter": "dbaeumer.vscode-eslint"
	},
	"[css]": {
		"editor.codeActionsOnSave": {
			"source.fixAll.eslint": "explicit",
			"source.organizeImports": "explicit"
		},
		"editor.defaultFormatter": "dbaeumer.vscode-eslint"
	},
	"[scss]": {
		"editor.codeActionsOnSave": {
			"source.fixAll.eslint": "explicit",
			"source.organizeImports": "explicit"
		},
		"editor.defaultFormatter": "dbaeumer.vscode-eslint"
	},
	"[postcss]": {
		"editor.codeActionsOnSave": {
			"source.fixAll.eslint": "explicit",
			"source.organizeImports": "explicit"
		},
		"editor.defaultFormatter": "dbaeumer.vscode-eslint"
	},
	"files.readonlyInclude": {
		"**/routeTree.gen.ts": true,
		"**/generated/models.py": true
	},
	"files.watcherExclude": {
		"**/.git/objects/**": true,
		"**/.git/subtree-cache/**": true,
		"**/.hg/store/**": true,
		"**/.dart_tool": true,
		"**/routeTree.gen.ts": true,
		"**/generated/models.py": true,
		"./.worktree/**": true
	},
	"search.exclude": {
		"**/node_modules": true,
		"**/bower_components": true,
		"**/*.code-search": true,
		"**/routeTree.gen.ts": true,
		"**/generated/models.py": true
	},
	"cSpell.words": [
		"Backoffice",
		"buildkit",
		"iovalkey",
		"Konva",
		"oslojs",
		"Pretendard",
		"SHADOWDB",
		"Turborepo",
		"uuidv",
		"Valkey"
	],
	"prisma.pinToPrisma6": false,
	"mypy-type-checker.cwd": "${workspaceFolder}/apps/worker",
	"git.detectWorktrees": true
}
