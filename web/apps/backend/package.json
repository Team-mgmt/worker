  "main": "index.js",
  "scripts": {
    "dev": "nest start --watch --watchAssets",
    "dev:anyopen": "cross-env HOST=0.0.0.0 nest start --watch --watchAssets",
    "lint": "eslint .",
    "build": "NODE_ENV=production nest build",
    "build:staging": "NODE_ENV=staging nest build",
    "build:dev": "NODE_ENV=development nest build",
    "check-types": "tsc --project tsconfig.build.json --noEmit",
    "check-types:test": "tsc --project tsconfig.test.json --noEmit",
    "start": "nest start",
    "clean": "rimraf dist",
    "test": "jest",
    "test:di": "jest --runTestsByPath test/app-di.spec.ts",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org YOUR_SENTRY_ORG --project YOUR_SENTRY_PROJECT ./dist && sentry-cli sourcemaps upload --org YOUR_SENTRY_ORG --project YOUR_SENTRY_PROJECT ./dist"
