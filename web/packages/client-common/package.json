{
  "name": "@shelfalign/client-common",
  "version": "1.0.0",
  "description": "Shared utilities for ShelfAlign frontend applications",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    },
    "./tokens.css": "./src/tokens.css",
    "./source.css": "./src/source.css"
  },
  "typesVersions": {
    "*": {
      "*": [
        "./dist/*.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --ext .ts,.tsx",
    "clean": "rimraf dist",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "keywords": [],
  "author": "",
  "license": "Proprietary",
  "dependencies": {
    "@shelfalign/schema": "workspace:^"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5",
    "@tanstack/react-router": "^1.168.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "ky": "^2.0.2",
    "lucide-react": "^1.11.0",
    "react": ">=19",
    "react-dom": ">=19",
    "react-error-boundary": ">=6",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "catalog:zod"
  },
  "devDependencies": {
    "@eslint/js": "catalog:eslint",
    "@storybook/react": "^10.3.6",
    "@storybook/react-vite": "^10.3.6",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.9",
    "@tanstack/react-router": "^1.169.2",
    "@types/react": "catalog:react",
    "eslint": "catalog:eslint",
    "eslint-config-prettier": "catalog:eslint",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "catalog:eslint",
    "globals": "^17.6.0",
    "react": "catalog:react",
    "react-dom": "catalog:react",
    "react-error-boundary": "^6.1.1",
    "rimraf": "^6.1.3",
    "storybook": "^10.3.6",
    "tailwindcss": "^4.2.4",
    "tsup": "^8.5.1",
    "typescript": "catalog:typescript",
    "typescript-eslint": "catalog:eslint"
  }
}
