{
  "name": "@shelfalign/schema",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    },
    "./auth/*": {
      "types": "./dist/auth/*.d.ts",
      "default": "./dist/auth/*.js"
    },
    "./auth/providers/*": {
      "types": "./dist/auth/providers/*.d.ts",
      "default": "./dist/auth/providers/*.js"
    },
    "./auth/credentials/*": {
      "types": "./dist/auth/credentials/*.d.ts",
      "default": "./dist/auth/credentials/*.js"
    },
    "./cache/*": {
      "types": "./dist/cache/*.d.ts",
      "default": "./dist/cache/*.js"
    },
    "./dtos/*": {
      "types": "./dist/dtos/*.d.ts",
      "default": "./dist/dtos/*.js"
    },
    "./dtos/admin/*": {
      "types": "./dist/dtos/admin/*.d.ts",
      "default": "./dist/dtos/admin/*.js"
    },
    "./dtos/service/*": {
      "types": "./dist/dtos/service/*.d.ts",
      "default": "./dist/dtos/service/*.js"
    },
    "./models/*": {
      "types": "./dist/models/*.d.ts",
      "default": "./dist/models/*.js"
    }
  },
  "typesVersions": {
    "*": {
      "dtos/*": [
        "./dist/dtos/*.d.ts"
      ],
      "dtos/admin/*": [
        "./dist/dtos/admin/*.d.ts"
      ],
      "dtos/service/*": [
        "./dist/dtos/service/*.d.ts"
      ],
      "auth/*": [
        "./dist/auth/*.d.ts"
      ],
      "auth/providers/*": [
        "./dist/auth/providers/*.d.ts"
      ],
      "auth/credentials/*": [
        "./dist/auth/credentials/*.d.ts"
      ],
      "cache/*": [
        "./dist/cache/*.d.ts"
      ],
      "models/*": [
        "./dist/models/*.d.ts"
      ],
      "*": [
        "./dist/*.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint . --ext .ts,.tsx",
    "clean": "rimraf dist",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "Proprietary",
  "dependencies": {
    "@shelfalign/database": "workspace:^",
    "zod": "catalog:zod"
  },
  "devDependencies": {
    "@eslint/js": "catalog:eslint",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "catalog:eslint",
    "eslint-config-prettier": "catalog:eslint",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "catalog:eslint",
    "globals": "^17.6.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "catalog:typescript",
    "typescript-eslint": "catalog:eslint",
    "vitest": "^4.1.5"
  }
}
