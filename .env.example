# Copy this file to .env and fill in secrets locally.
# Never commit real API keys.

# Local Docker PostgreSQL used by the web Prisma schema.
DATABASE_URL=postgresql+psycopg://shelfalign:shelfalign@localhost:5432/shelfalign

# Data4Library API key for catalog sync.
JUNGBO_NARU_API_KEY=

# VLM provider. OPENAI_API_KEY is enough for the default OpenAI setup.
OPENAI_API_KEY=
VLM_API_KEY=
VLM_API_BASE_URL=https://api.openai.com/v1
VLM_MODEL=gpt-4o-mini

# Legacy/local keys; keep blank unless a script explicitly needs them.
ANTHROPIC_API_KEY=
NL_API_KEY=
